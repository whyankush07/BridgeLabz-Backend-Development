<!DOCTYPE html>
<html>

<head>
    <title>Photo Gallery</title>
    <style>
        .gallery {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }

        img {
            width: 600px;
            height: 250px;
            object-fit: cover;
            border-radius: 10px;
        }
    </style>
</head>

<body>

    <h1>My Photo Gallery</h1>

    <div class="gallery">
        <% images.forEach(function(image) { %>
            <img src="/<%= image %>" alt="Photo">
            <% }); %>
    </div>

</body>

</html>